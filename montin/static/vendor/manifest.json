    "default_style": "github-dark",
    "css_file": "{style}.min.css",
    "cdn_css": "https://cdnjs.cloudflare.com/ajax/libs/highlight.js/{version}/styles/{style}.min.css",
    "vendored_styles": [
      "github-dark",
      "github"
    ],
    "sri_css": {
      "github-dark": "sha384-wH75j6z1lH97ZOpMOInqhgKzFkAInZPPSPlZpYKYTOqsaizPvhQZmAtLcPKXpLyH",
      "github": "sha384-eFTL69TLRZTkNfYZOLM+G04821K1qZao/4QLJbet1pP4tcF+fdXq/9CdqAbWRl/L"
    },
    "licenses": [
      {
        "file": "LICENSE",
        "url": "https://cdn.jsdelivr.net/npm/highlight.js@{version}/LICENSE"
      }
    ]
  },
  "mathjax": {
    "version": "3.2.2",
    "default_output": "svg",
    "js": "tex-{output}.js",
    "cdn": "https://cdn.jsdelivr.net/npm/mathjax@{version}/es5/tex-{output}.js",
    "vendored_outputs": [
      "svg"
    ],
    "sri": {
      "svg": "sha384-KKWa9jJ1MZvssLeOoXG6FiOAZfAgmzsIIfw8BXwI9+kYm0lPCbC6yTQPBC00F1/L"
    },
    "licenses": [
      {
        "file": "LICENSE",
        "url": "https://cdn.jsdelivr.net/npm/mathjax@{version}/LICENSE"
      }
    ]
  },
  "tabulator": {
    "version": "6.3.1",
    "js": "tabulator.min.js",
    "cdn_js": "https://cdn.jsdelivr.net/npm/tabulator-tables@{version}/dist/js/tabulator.min.js",
    "sri_js": "sha384-SKSq3cuuVWdfrjtLz9wNlqE0bMc903yMS5zGnFtwvfddplgxa1hywtiLyw1CbSHO",
    "default_theme": "dark",
    "css_file": "{theme}.min.css",
    "cdn_css": "https://cdn.jsdelivr.net/npm/tabulator-tables@{version}/dist/css/{theme}.min.css",
    "vendored_themes": [
      "tabulator",
      "tabulator_midnight"
    ],
    "theme_map": {
      "light": "tabulator",
      "dark": "tabulator_midnight"
    },
    "sri_css": {
      "tabulator": "sha384-p6hY5g6BjbrEVoCLwj4gZMkotMaHdQrPkd4S0vRpErDxL9/kvjyaUIq/S9RAPQfL",
