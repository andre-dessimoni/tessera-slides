{
  "_comment": "Single source of truth for vendored plugin libraries. Each top-level key is a library; its files live in a subfolder of the same name (e.g. plotly/plotly.min.js) alongside its LICENSE file(s). Edit version pins / styles here, then run `python scripts/update_vendor.py` to download the code + licenses and refresh the `sri` hashes. Filenames are version-free (a bump overwrites in place); {version}/{style}/{output} are substituted at resolve time. See montin/utils/vendor.py.",
  "plotly": {
    "version": "2.35.2",
    "js": "plotly.min.js",
    "cdn": "https://cdn.plot.ly/plotly-{version}.min.js",
    "sri": "sha384-cCVCZkAjYNxaYKbM8lsArLznDF/SvMFr1jcZrvOpSTCa0W40ZAdLzHCEulnUa5i7",
    "licenses": [
      {
        "file": "LICENSE",
        "url": "https://cdn.jsdelivr.net/npm/plotly.js-dist-min@{version}/LICENSE"
      },
      {
        "file": "LICENSE.txt",
        "url": "https://cdn.jsdelivr.net/npm/plotly.js@{version}/dist/plotly.min.js.LICENSE.txt"
      }
    ]
  },
  "mermaid": {
    "version": "11.4.1",
    "js": "mermaid.min.js",
    "cdn": "https://cdn.jsdelivr.net/npm/mermaid@{version}/dist/mermaid.min.js",
