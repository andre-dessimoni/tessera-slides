    "licenses": [
      {
        "file": "LICENSE",
        "url": "https://cdn.jsdelivr.net/npm/mermaid@{version}/LICENSE"
      }
    ]
  },
  "highlight": {
    "version": "11.10.0",
    "js": "highlight.min.js",
    "cdn_js": "https://cdnjs.cloudflare.com/ajax/libs/highlight.js/{version}/highlight.min.js",
